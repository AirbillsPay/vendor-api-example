{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Airbills",
  "theme": "aspen",
  "logo": {
    "light": "https://raw.githubusercontent.com/AirbillsPay/vendor-api-example/refs/heads/main/docs/images/logopng.png",
    "dark": "https://raw.githubusercontent.com/AirbillsPay/vendor-api-example/refs/heads/main/docs/images/logopng.png"
  },
  "favicon": {
    "light": "https://raw.githubusercontent.com/AirbillsPay/vendor-api-example/refs/heads/main/docs/images/logo1jpeg.jpg",
